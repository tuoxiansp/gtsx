{
  "name": "gtsx",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gtsx": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
