{
  "name": "gtsx",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gtsx": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./project-index": {
      "types": "./dist/project-index.d.ts",
      "import": "./dist/project-index.js"
    },
    "./studio/manifest": {
      "types": "./dist/studio-manifest-model.d.ts",
      "import": "./dist/studio-manifest-model.js"
    },
    "./studio/server": {
      "types": "./dist/studio-manifest.d.ts",
      "import": "./dist/studio-manifest.js"
    },
    "./studio/client": {
      "types": "./dist/studio-client.d.ts",
      "import": "./dist/studio-client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
