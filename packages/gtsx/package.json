{
  "name": "gtsx",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "gtsx": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./project-index": {
      "types": "./dist/project-index.d.ts",
      "import": "./dist/project-index.js",
      "default": "./dist/project-index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "default": "./dist/config.js"
    },
    "./config-model": {
      "types": "./dist/config-model.d.ts",
      "import": "./dist/config-model.js",
      "default": "./dist/config-model.js"
    },
    "./preview-protocol": {
      "types": "./dist/preview-protocol.d.ts",
      "import": "./dist/preview-protocol.js",
      "default": "./dist/preview-protocol.js"
    },
    "./react-transform": {
      "types": "./dist/react-transform.d.ts",
      "import": "./dist/react-transform.js",
      "default": "./dist/react-transform.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "playwright": "^1.60.0",
    "react-tracked": "^2.0.1",
    "scheduler": "^0.27.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/react-test-renderer": "^19.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-test-renderer": "^19.2.6"
  }
}
