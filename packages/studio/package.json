{
  "name": "@gtsx/studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client-entry.ts",
      "import": "./src/client-entry.ts"
    },
    "./manifest": {
      "types": "./src/manifest.ts",
      "import": "./src/manifest.ts"
    },
    "./manifest-server": {
      "types": "./src/manifest-server.ts",
      "import": "./src/manifest-server.ts"
    }
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "gtsx:check": "gtsx check src",
    "gtsx:serve": "gtsx serve",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gtsx/adapter-vite-react": "workspace:*",
    "@gtsx/preview-react": "workspace:*",
    "@vitejs/plugin-react": "^5.1.2",
    "gtsx": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
