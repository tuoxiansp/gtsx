{
  "name": "@gtsx/preview-react",
  "version": "0.0.1",
  "description": "React preview runtime for GTSX component cases.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuoxiansp/gtsx.git",
    "directory": "packages/preview-react"
  },
  "bugs": {
    "url": "https://github.com/tuoxiansp/gtsx/issues"
  },
  "homepage": "https://github.com/tuoxiansp/gtsx#readme",
  "keywords": [
    "gtsx",
    "react",
    "preview",
    "component-preview"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "@gtsx/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
