{
  "name": "@gtsx/adapter-next-react",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./index.cjs",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./preview-entries": {
      "types": "./dist/preview-entries.d.ts",
      "import": "./dist/preview-entries.js",
      "default": "./dist/preview-entries.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./preview-route": {
      "types": "./dist/preview-route.d.ts",
      "import": "./dist/preview-route.js",
      "default": "./dist/preview-route.js"
    },
    "./loader": "./loader.cjs"
  },
  "files": [
    "dist",
    "index.cjs",
    "loader.cjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@gtsx/preview-react": "workspace:*"
  },
  "peerDependencies": {
    "gtsx": "workspace:*",
    "next": ">=13",
    "react": ">=18"
  }
}
