{
  "name": "@gtsx/playground-vite-react-ts-tanstack-router",
  "private": true,
  "type": "module",
  "scripts": {
    "gtsx:check": "gtsx check src/routes/AppRoute.g.tsx",
    "gtsx:serve": "gtsx serve src/routes/AppRoute.g.tsx --case createVitePnpmFailure --port 4303",
    "gtsx:capture": "gtsx capture src/routes/AppRoute.g.tsx --all --out ../../snapshots/vite-react-ts-tanstack-router",
    "gtsx:strip": "gtsx strip --check",
    "dev": "node scripts/playground-adapter.mjs serve",
    "capture": "node scripts/playground-adapter.mjs capture",
    "strip:gtsx": "node scripts/playground-adapter.mjs strip"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "gtsx": "workspace:*",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vite": "^8.0.14"
  }
}
